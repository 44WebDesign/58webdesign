{
  "name": "58webdesign",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "pages:dev": "wrangler pages dev --port 3000 --compatibility-date=2024-04-03 --proxy 3001 -- npm run dev:vite",
    "dev:vite": "vite --port 3001 --host 0.0.0.0",
    "build": "npm run clean && vite build && tsc -p tsconfig.server.json",
    "build:pages": "npm run clean && vite build",
    "start": "NODE_ENV=production node dist-server/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
